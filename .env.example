# ========================================
# API HUB - Configuração de Ambiente (.env)
# ========================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha suas chaves de API
# 3. NUNCA commite o arquivo .env no Git!
# 
# ========================================

# 🤖 GOOGLE GEMINI API
# Obtenha em: https://aistudio.google.com/
# Passo a passo:
#   1. Acesse https://aistudio.google.com/app/apikey
#   2. Clique em "Create API Key"
#   3. Copie a chave gerada
# Limite gratuito: 15 requisições por minuto
GEMINI_API_KEY=sua_chave_gemini_aqui

# 🌌 NASA API
# Obtenha em: https://api.nasa.gov/
# Passo a passo:
#   1. Acesse https://api.nasa.gov/
#   2. Preencha o formulário com seu email
#   3. Você receberá uma chave por email
# Limite gratuito: 50 requisições por hora
NASA_API_KEY=sua_chave_nasa_aqui

# 💰 COINECKO API
# Status: NÃO REQUER CHAVE! 100% Gratuito
# Deixe comentado ou em branco
# COINGECKO_API_KEY=nao_necessario

# ========================================
# CONFIGURAÇÕES OPCIONAIS
# ========================================

# Modelo do Gemini a usar
# Opções: gemini-2.5-flash (recomendado)
# Padrão: gemini-3-flash-preview
GEMINI_MODEL=gemini-2.5-flash

# Temperatura da IA (controla criatividade)
# Intervalo: 0.0 - 2.0
# 0.0 = mais determinístico, 2.0 = mais criativo
# Padrão: 1.0
GEMINI_TEMPERATURE=1.0

# Número máximo de mensagens mantidas no histórico
# Padrão: 10
MAX_MEMORY_MESSAGES=10

# Diretório para salvar imagens baixadas da NASA
# Padrão: ./images
IMAGES_DIR=./images